# Database (Supabase PostgreSQL)
DATABASE_URL='postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true'
DIRECT_URL='postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres'

# Auth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_xxxxx

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_A2P_PRICE_ID=price_xxxxx
STRIPE_BLUE_SHARED_PRICE_ID=price_xxxxx
STRIPE_BLUE_DEDICATED_PRICE_ID=price_xxxxx

# Encryption (for provider credentials - defaults to NEXTAUTH_SECRET if not set)
ENCRYPTION_SECRET=your-encryption-secret

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=xxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxx

# AI (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Cron Security
CRON_SECRET=your-cron-secret

# Demo Mode (comma-separated church IDs that won't send real SMS)
DEMO_CHURCH_IDS=
